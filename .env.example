# Move & Meet — environment variables (example file, committed to repo)
#
# Copy this file to `.env.local` for local development. Do NOT commit `.env.local`.
# Production and Preview values are configured in the Cloudflare Pages dashboard.

# Public site URL used in SEO, OpenGraph, and absolute internal links.
# Local dev: http://localhost:3000
# Preview:   https://<branch>.move-and-meet.pages.dev
# Prod:      https://movemeet.ch
NEXT_PUBLIC_SITE_URL=http://localhost:3000
