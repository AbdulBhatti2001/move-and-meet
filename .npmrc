# Force pnpm to use a flat, hoisted node_modules layout.
#
# Without this, pnpm's default symlink-based store layout breaks
# @opennextjs/cloudflare's static analysis of Next.js's
# middleware-manifest.json — the manifest path resolves through a
# symlink that esbuild cannot follow at bundle time, so it emits a
# runtime dynamic require that crashes on Cloudflare Workers' V8
# isolate. See opennextjs-cloudflare #922 / #1232 and
# cloudflare/workers-sdk #10236.
#
# Cost: slightly larger node_modules on disk, no functional impact
# on dev or build.

shamefully-hoist=true
node-linker=hoisted
